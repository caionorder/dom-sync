# Google Ad Manager
GAM_KEY_FILE=/path/to/service-account-key.json

# MongoDB
MONGO_HOST=cluster.mongodb.net
MONGO_PORT=27017
MONGO_DB=admanager
MONGO_USER=your_user
MONGO_PASSWORD=your_password
MONGO_AUTH_SOURCE=admin
MONGO_REPLICA_SET=
MONGO_TLS=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
